# FAH Explorer — environment template. Copy to .env and fill in. Never commit .env.

# Anthropic Claude — used for LLM-assisted extraction (docs/07)
ANTHROPIC_API_KEY=sk-ant-...

# Database — defaults to SQLite from settings.yaml; override for PostGIS later
# DB_URL=postgresql+psycopg://user:pass@localhost:5432/fah_explorer

# Optional: override the extraction model / OCR language
# FAH_EXTRACTION_MODEL=claude-opus-4-8
# FAH_OCR_LANGUAGE=eng

# Optional: app log level (DEBUG | INFO | WARNING | ERROR)
# FAH_LOG_LEVEL=INFO
