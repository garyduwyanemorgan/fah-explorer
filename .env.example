# FAH Explorer — environment template. Copy to .env and fill in. Never commit .env.

# ── Required for LLM extraction ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Required for production ────────────────────────────────────────────────
# Web UI password. Set this to enable authentication. Leave unset for dev/local use.
FAH_PASSWORD=change-me-before-deploy

# ── Optional overrides ─────────────────────────────────────────────────────
# Database — defaults to SQLite (data/fah_explorer.db); uncomment for PostGIS
# DB_URL=postgresql+psycopg://user:pass@localhost:5432/fah_explorer

# Extraction model (must be vision-capable for scanned PDFs)
# FAH_EXTRACTION_MODEL=claude-opus-4-8

# OCR language (ISO 639-2 code; requires the matching Tesseract language pack)
# FAH_OCR_LANGUAGE=eng

# Log level: DEBUG | INFO | WARNING | ERROR
# FAH_LOG_LEVEL=INFO
